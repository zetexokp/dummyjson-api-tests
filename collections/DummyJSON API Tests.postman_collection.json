      "item": [
        {
          "name": "Get User Carts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"Response contains carts array\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData).to.have.property(\"carts\");\r",
                  "    pm.expect(jsonData.carts).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"Each cart has required fields\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    jsonData.carts.forEach(cart => {\r",
                  "        pm.expect(cart).to.have.property(\"id\");\r",
                  "        pm.expect(cart).to.have.property(\"products\");\r",
                  "        pm.expect(cart).to.have.property(\"total\");\r",
                  "        pm.expect(cart).to.have.property(\"userId\");\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"Cart belongs to requested user\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    jsonData.carts.forEach(cart => {\r",
                  "        pm.expect(cart.userId).to.eql(1);\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Save cart id\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    const cartId = jsonData.carts[0].id;\r",
                  "\r",
                  "    pm.environment.set(\"cartId\", cartId);\r",
                  "\r",
                  "    pm.expect(pm.environment.get(\"cartId\")).to.eql(cartId);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
