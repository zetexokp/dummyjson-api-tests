      "item": [
        {
          "name": "Login Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Access token is returned\", function () {\r",
                  "    pm.expect(response.accessToken).to.exist;\r",
                  "    pm.expect(response.accessToken).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User id is returned\", function () {\r",
                  "    pm.expect(response.id).to.exist;\r",
                  "    pm.expect(response.id).to.be.a(\"number\");\r",
                  "});\r",
                  "\r",
                  "// Save data for next requests\r",
                  "pm.environment.set(\"token\", response.accessToken);\r",
                  "pm.environment.set(\"userId\", response.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
